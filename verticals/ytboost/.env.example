# YtBoost — Environment Variables
# Copy to .env.local and fill in values

# === Public (exposed to browser) ===
NEXT_PUBLIC_CF_API_URL=https://api.ytboost.dev
NEXT_PUBLIC_CF_BRAND_NAME=YtBoost
NEXT_PUBLIC_CF_PRIMARY_COLOR=#FF0000

# === Server-side only (never exposed to browser) ===
CF_API_KEY=cf_live_your_api_key_here
